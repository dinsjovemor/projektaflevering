<Window x:Class="projektaflevering.RedigerBegivenhedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rediger begivenhed" Height="380" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Titel:" Margin="0,0,0,4"/>
        <TextBox x:Name="TitelBox" Margin="0,0,0,12"/>

        <TextBlock Text="Dag:" Margin="0,0,0,4"/>
        <ComboBox x:Name="DagBox" Margin="0,0,0,12"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Start (TT:MM):" Margin="0,0,0,4"/>
                <TextBox x:Name="StartBox"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Slut (TT:MM):" Margin="0,0,0,4"/>
                <TextBox x:Name="SlutBox"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Tilknyttet flow:" Margin="0,0,0,4"/>
        <ComboBox x:Name="FlowBox" Margin="0,0,0,12"/>

        <CheckBox x:Name="SynligCheckBox"
                  Content="Synlig for studerende"
                  Margin="0,0,0,16"/>

        <TextBlock x:Name="FejlTekst" Foreground="Red" Margin="0,0,0,8"/>
        <Button Content="Gem ændringer" Click="GemKnap_Click"/>
    </StackPanel>
</Window>
