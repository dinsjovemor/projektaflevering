<Window x:Class="projektaflevering.TilfoejFlowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tilføj flow" Height="310" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Titel:" Margin="0,0,0,4"/>
        <TextBox x:Name="TitelBox" Margin="0,0,0,12"/>

        <TextBlock Text="Beskrivelse:" Margin="0,0,0,4"/>
        <TextBox x:Name="BeskrivelseBox" Height="60" TextWrapping="Wrap"
                 AcceptsReturn="True" Margin="0,0,0,16"/>
        <CheckBox x:Name="Udgiv" Content="Publicer" Checked="CheckBox_Checked"/>

        <TextBlock x:Name="FejlTekst" Foreground="Red" Margin="0,0,0,8"/>

        <Button Content="Tilføj" Click="TilfoejKnap_Click"/>
    </StackPanel>
</Window>
