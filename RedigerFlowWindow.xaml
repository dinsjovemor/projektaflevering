<Window x:Class="projektaflevering.RedigerFlowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rediger flow" Height="250" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Titel:" Margin="0,0,0,4"/>
        <TextBox x:Name="TitelBox" Margin="0,0,0,12"/>

        <TextBlock Text="Beskrivelse:" Margin="0,0,0,4"/>
        <TextBox x:Name="BeskrivelseBox" Height="60" TextWrapping="Wrap"
                 AcceptsReturn="True" Margin="0,0,0,16"/>

        <TextBlock x:Name="FejlTekst" Foreground="Red" Margin="0,0,0,8"/>
        <Button Content="Gem ændringer" Click="GemKnap_Click"/>
    </StackPanel>
</Window>
