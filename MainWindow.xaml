<Window x:Class="projektaflevering.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Week Schedule" Height="600" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Knap-række øverst – kun synlig for undervisere -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8"
                    x:Name="UnderviserPanel" Visibility="Collapsed">
            <Button Content="Tilføj begivenhed" Click="TilfoejKnap_Click" Padding="8,4"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="BodyGrid"/>
        </ScrollViewer>
    </Grid>
</Window>
