<Window x:Class="projektaflevering.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ugeskema" Height="660" Width="920">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Knap-række øverst – kun synlig for undervisere -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8"
                    x:Name="UnderviserPanel" Visibility="Collapsed">
            <Button Content="Tilføj begivenhed" Click="TilfoejBegivenhedKnap_Click"
                    Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="Tilføj flow" Click="TilfoejFlowKnap_Click" Padding="8,4"/>
        </StackPanel>

        <!-- TabControl med navn så vi kan skifte tab i koden -->
        <TabControl Grid.Row="1" x:Name="HovedTab">

            <!-- Faneblad 1: Ugeskema -->
            <TabItem Header="Ugeskema">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="SkemaGrid"/>
                </ScrollViewer>
            </TabItem>

            <!-- Faneblad 2: Flows -->
            <TabItem Header="Flows">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- Knapper til underviser nederst -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Liste over flows til venstre -->
                    <ListBox Grid.Row="0" Grid.Column="0"
                             x:Name="FlowListe"
                             SelectionChanged="FlowListe_SelectionChanged"
                             Margin="0,0,8,0"/>

                    <!-- Detaljevisning til højre -->
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Titel:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="FlowTitelTekst" FontSize="14" Margin="0,0,0,12"/>

                        <TextBlock Text="Beskrivelse:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="FlowBeskrivelseTekst" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Rediger/Slet knapper – kun synlig for undervisere -->
                    <StackPanel Grid.Row="1" Grid.Column="0"
                                x:Name="UnderviserFlowKnapPanel"
                                Orientation="Horizontal"
                                Visibility="Collapsed"
                                Margin="0,8,0,0">
                        <Button Content="Rediger valgt" Click="RedigerFlowKnap_Click"
                                Padding="8,4" Margin="0,0,8,0"/>
                        <Button Content="Slet valgt" Click="SletFlowKnap_Click" Padding="8,4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
