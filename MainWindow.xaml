<Window x:Class="projektaflevering.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ugeskema" Height="640" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Knap-række øverst – kun synlig for undervisere -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8"
                    x:Name="UnderviserPanel" Visibility="Collapsed">
            <Button Content="Tilføj begivenhed" Click="TilfoejBegivenhedKnap_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="Tilføj flow" Click="TilfoejFlowKnap_Click" Padding="8,4"/>
        </StackPanel>

        <!-- Tab-kontrol med to faneblade -->
        <TabControl Grid.Row="1">

            <!-- Faneblad 1: Ugeskema -->
            <TabItem Header="Ugeskema">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="SkemaGrid"/>
                </ScrollViewer>
            </TabItem>

            <!-- Faneblad 2: Flow-oversigt -->
            <TabItem Header="Flows">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Liste over flows til venstre -->
                    <ListBox Grid.Column="0" x:Name="FlowListe"
                             SelectionChanged="FlowListe_SelectionChanged"
                             Margin="0,0,8,0"/>

                    <!-- Detaljer til højre -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Titel:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="FlowTitelTekst" Margin="0,0,0,12" FontSize="14"/>

                        <TextBlock Text="Beskrivelse:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="FlowBeskrivelseTekst" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
