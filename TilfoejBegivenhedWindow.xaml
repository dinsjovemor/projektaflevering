<Window x:Class="projektaflevering.TilfoejBegivenhedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tilføj begivenhed" Height="300" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Titel:" Margin="0,0,0,4"/>
        <TextBox x:Name="TitelBox" Margin="0,0,0,12"/>

        <TextBlock Text="Dag:" Margin="0,0,0,4"/>
        <ComboBox x:Name="DagBox" Margin="0,0,0,12"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Start (HH:MM):" Margin="0,0,0,4"/>
                <TextBox x:Name="StartBox" Text="09:00"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Slut (HH:MM):" Margin="0,0,0,4"/>
                <TextBox x:Name="SlutBox" Text="10:00"/>
            </StackPanel>
        </Grid>
        <CheckBox x:Name="udgivelsesknap" Content="Udgiv til skemaet"/>

        <TextBlock x:Name="FejlTekst" Foreground="Red" Margin="0,0,0,8"/>

        <Button Content="Tilføj" Click="TilfoejKnap_Click"/>
    </StackPanel>
</Window>
